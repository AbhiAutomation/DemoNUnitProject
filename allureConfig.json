{
    "allure": {
        "directory": "../../../allure-results" // ../../../ = path navigation to go up three levels from the current directory where the tests are executed, and then into the allure-results directory. This is useful when you want to keep the allure results outside of the test project directory, for example, in a centralized location for all test results.
        //  "directory": "allure-results"
    }
}

// in docekr command -v host_path:container_path ${PWD}\allure-resultsis Host machine path and /app/allure-results is the path inside the container where the allure results will be stored. This allows you to access the allure results generated by the tests running inside the container on your host machine.
